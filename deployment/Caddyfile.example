chambres-dhotes-albi.com, admin.chambres-dhotes-albi.com {
  encode gzip

  handle /api/* {
    reverse_proxy 127.0.0.1:3000
  }

  handle /health {
    reverse_proxy 127.0.0.1:3000
  }

  handle /ready {
    reverse_proxy 127.0.0.1:3000
  }

  handle /live {
    reverse_proxy 127.0.0.1:3000
  }

  handle {
    reverse_proxy 127.0.0.1:5173
  }
}

