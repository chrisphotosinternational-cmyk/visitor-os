# VISITOR-OS external SaaS deployment example.
# Do not use OVH Web mutualise/performance for the backend.

NODE_ENV=production
APP_NAME=VISITOR-OS
HOST=0.0.0.0
PORT=3000
LOG_LEVEL=info

# Managed PostgreSQL URL from Render, Railway, Fly.io or DigitalOcean.
DATABASE_URL=postgresql://user:password@host:5432/visitor_os
DATABASE_SSL=false
DATABASE_CONNECTION_TIMEOUT_MS=5000

VISITOR_OS_API_URL=https://api.visitor-os.example
ALLOWED_ORIGINS=https://chambres-dhotes-albi.com,https://admin.visitor-os.example

SHUTDOWN_TIMEOUT_MS=10000
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=120

ADMIN_SESSION_SECRET=replace-with-at-least-32-random-characters
ADMIN_SESSION_TTL_MS=86400000
ADMIN_SESSION_RENEWAL_MS=3600000

FIRST_ADMIN_EMAIL=admin@chambres-dhotes-albi.com
FIRST_ADMIN_PASSWORD=replace-with-a-long-temporary-password
FIRST_ADMIN_FIRST_NAME=VISITOR
FIRST_ADMIN_LAST_NAME=Admin
FIRST_ADMIN_ORGANIZATION_ID=00000000-0000-4000-8000-000000000001

OPENAI_API_KEY=
RESEND_API_KEY=
NOTIFICATION_FROM_EMAIL=notifications@chambres-dhotes-albi.com
NOTIFICATION_RETRY_ATTEMPTS=2
NOTIFICATION_TIMEOUT_MS=5000

# KMS beta storage: extracted text, versions and chunks are stored in managed PostgreSQL.
# Do not rely on local disk for KMS files on managed cloud platforms.
KMS_STORAGE_PROVIDER=database
