{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "RAILPACK",
    "buildCommand": "pnpm --dir backend install --frozen-lockfile && pnpm --dir backend build",
    "watchPatterns": [
      "/backend/**",
      "/configs/**",
      "/railpack.json",
      "/railway.json",
      "/package.json"
    ]
  },
  "deploy": {
    "startCommand": "pnpm --dir backend start",
    "healthcheckPath": "/ready",
    "healthcheckTimeout": 120,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}
