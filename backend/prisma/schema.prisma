generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Organization {
  id        String   @id @db.Uuid
  name      String
  slug      String   @unique
  users     User[]
  prospects Prospect[]
  contactHistory ContactHistory[]
  messageTemplates MessageTemplate[]
  messageTemplateUsage MessageTemplateUsage[]
  prospectAiAnalysis ProspectAiAnalysis[]
  prospectEnrichments ProspectEnrichment[]
  prospectFieldSuggestions ProspectFieldSuggestion[]
  crmActivityLog CrmActivityLog[]
  auditTrail AuditTrail[]
  appSettings AppSetting[]
  aiChatSessions AiChatSession[]
  aiChatMessages AiChatMessage[]
  siteQaItems SiteQaItem[]
  chatbotUnansweredQuestions ChatbotUnansweredQuestion[]
  chatbotIntents ChatbotIntent[]
  knowledgeItems KnowledgeItem[]
  conversationFlows ConversationFlow[]
  chatbotPersonality ChatbotPersonality[]
  chatbotGoals ChatbotGoal[]
  knowledgeSuggestions KnowledgeSuggestion[]
  chatbotStudios ChatbotStudio[]
  chatbotStudioVersions ChatbotStudioVersion[]
  chatbotImportProposals ChatbotImportProposal[]
  chatbotSimulations ChatbotSimulation[]
  visitorConversationContexts VisitorConversationContext[]
  reasoningTraces ReasoningTrace[]
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  @@index([createdAt])
  @@map("organizations")
}

model User {
  id             String       @id @db.Uuid
  organizationId String       @map("organization_id") @db.Uuid
  firstName      String       @map("first_name")
  lastName       String       @map("last_name")
  email          String
  passwordHash   String?      @map("password_hash")
  role           UserRole
  status         UserStatus   @default(active)
  createdAt      DateTime     @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime     @default(now()) @map("updated_at") @db.Timestamptz
  organization   Organization @relation(fields: [organizationId], references: [id])
  contactHistory ContactHistory[]
  messageTemplates MessageTemplate[]
  messageTemplateUsage MessageTemplateUsage[]
  crmActivityLog CrmActivityLog[]
  auditTrail AuditTrail[]
  aiChatSessions AiChatSession[]
  aiChatMessages AiChatMessage[]

  @@unique([organizationId, email])
  @@index([organizationId, role, status])
  @@map("users")
}

enum UserRole {
  SuperAdmin
  Admin
  Manager
  Agent
  Viewer
}

enum UserStatus {
  active
  inactive
  invited
  suspended
}

model Prospect {
  id             String              @id @db.Uuid
  organizationId String              @map("organization_id") @db.Uuid
  firstName      String?             @map("first_name")
  lastName       String?             @map("last_name")
  pseudo         String?
  company        String?
  email          String?
  phone          String?
  website        String?
  instagram      String?
  twitterX       String?             @map("twitter_x")
  mym            String?
  onlyfans       String?
  linktree       String?
  allmylinks     String?
  city           String?
  activity       String?
  description    String?
  sourceUrl      String?             @map("source_url")
  status         ProspectStatus      @default(new)
  score          Int                 @default(40)
  scoreLabel     ProspectScoreLabel  @default(medium) @map("score_label")
  notes          String?
  createdAt      DateTime            @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime            @default(now()) @map("updated_at") @db.Timestamptz
  organization   Organization        @relation(fields: [organizationId], references: [id])
  contactHistory ContactHistory[]
  messageTemplateUsage MessageTemplateUsage[]
  aiAnalysis      ProspectAiAnalysis[]
  enrichments     ProspectEnrichment[]
  fieldSuggestions ProspectFieldSuggestion[]
  crmActivityLog   CrmActivityLog[]

  @@index([organizationId, status])
  @@index([organizationId, scoreLabel])
  @@index([organizationId, city])
  @@index([organizationId, updatedAt, createdAt])
  @@index([organizationId, score, updatedAt])
  @@map("prospects")
}

enum ProspectStatus {
  new
  to_qualify
  to_contact
  contacted
  interested
  refused
  follow_up
  potential_client
  signed_client
  blacklist
}

enum ProspectScoreLabel {
  very_high
  high
  medium
  low
  ignore
}

model ContactHistory {
  id             String         @id @db.Uuid
  organizationId String         @map("organization_id") @db.Uuid
  prospectId     String         @map("prospect_id") @db.Uuid
  userId         String?        @map("user_id") @db.Uuid
  contactDate    DateTime       @default(now()) @map("contact_date") @db.Timestamptz
  channel        ContactChannel
  messageUsed    String?        @map("message_used")
  response       String?
  outcome        ContactOutcome
  nextAction     String?        @map("next_action")
  followUpDate   DateTime?      @map("follow_up_date") @db.Timestamptz
  notes          String?
  createdAt      DateTime       @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime       @default(now()) @map("updated_at") @db.Timestamptz
  organization   Organization   @relation(fields: [organizationId], references: [id])
  prospect       Prospect       @relation(fields: [prospectId], references: [id])
  user           User?          @relation(fields: [userId], references: [id])

  @@index([prospectId, contactDate])
  @@index([organizationId, followUpDate])
  @@index([organizationId, outcome])
  @@index([organizationId, createdAt])
  @@index([organizationId, contactDate])
  @@index([organizationId, userId, contactDate])
  @@map("contact_history")
}

enum ContactChannel {
  email
  phone
  whatsapp_manual
  instagram_manual
  x_manual
  mym_manual
  onlyfans_manual
  website_form
  other
}

enum ContactOutcome {
  no_response
  positive
  negative
  interested
  not_now
  booked
  blacklist
  follow_up_needed
}

model MessageTemplate {
  id              String                 @id @db.Uuid
  organizationId  String                 @map("organization_id") @db.Uuid
  name            String
  channel         MessageTemplateChannel
  purpose         MessageTemplatePurpose
  content         String
  variables       Json                   @default("[]")
  isActive        Boolean                @default(true) @map("is_active")
  createdByUserId String?                @map("created_by_user_id") @db.Uuid
  createdAt       DateTime               @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime               @default(now()) @map("updated_at") @db.Timestamptz
  organization    Organization           @relation(fields: [organizationId], references: [id])
  createdBy       User?                  @relation(fields: [createdByUserId], references: [id])
  usage           MessageTemplateUsage[]

  @@index([organizationId, isActive])
  @@map("message_templates")
}

model MessageTemplateUsage {
  id              String          @id @db.Uuid
  organizationId  String          @map("organization_id") @db.Uuid
  templateId      String          @map("template_id") @db.Uuid
  prospectId      String?         @map("prospect_id") @db.Uuid
  userId          String?         @map("user_id") @db.Uuid
  action          String
  renderedContent String          @map("rendered_content")
  createdAt       DateTime        @default(now()) @map("created_at") @db.Timestamptz
  organization    Organization    @relation(fields: [organizationId], references: [id])
  template        MessageTemplate @relation(fields: [templateId], references: [id])
  prospect        Prospect?       @relation(fields: [prospectId], references: [id])
  user            User?           @relation(fields: [userId], references: [id])

  @@index([organizationId, createdAt])
  @@index([templateId, createdAt])
  @@map("message_template_usage")
}

enum MessageTemplateChannel {
  email
  phone_script
  whatsapp_manual
  instagram_manual
  x_manual
  mym_manual
  onlyfans_manual
  website_form
  other
}

enum MessageTemplatePurpose {
  first_contact
  follow_up
  proposal
  reactivation
  thank_you
  refusal_response
  custom
}

model ProspectAiAnalysis {
  id               String                 @id @db.Uuid
  organizationId   String                 @map("organization_id") @db.Uuid
  prospectId       String                 @map("prospect_id") @db.Uuid
  summary          String
  strengths        Json                   @default("[]")
  weaknesses       Json                   @default("[]")
  opportunities    Json                   @default("[]")
  risks            Json                   @default("[]")
  recommendedOffer String                 @map("recommended_offer")
  priority         AiQualificationPriority
  confidence       Int
  createdAt        DateTime               @default(now()) @map("created_at") @db.Timestamptz
  updatedAt        DateTime               @default(now()) @map("updated_at") @db.Timestamptz
  organization     Organization           @relation(fields: [organizationId], references: [id])
  prospect         Prospect               @relation(fields: [prospectId], references: [id])

  @@index([prospectId, createdAt])
  @@index([organizationId, priority, confidence])
  @@index([organizationId, createdAt])
  @@index([prospectId, organizationId, createdAt])
  @@map("prospect_ai_analysis")
}

enum AiQualificationPriority {
  very_high
  high
  medium
  low
}

model ProspectEnrichment {
  id                  String                 @id @db.Uuid
  organizationId      String                 @map("organization_id") @db.Uuid
  prospectId          String                 @map("prospect_id") @db.Uuid
  sourceType          EnrichmentSourceType   @map("source_type")
  sourceUrl           String                 @map("source_url")
  pageTitle           String?                @map("page_title")
  metaDescription     String?                @map("meta_description")
  detectedEmails      Json                   @default("[]") @map("detected_emails")
  detectedPhones      Json                   @default("[]") @map("detected_phones")
  detectedSocialLinks Json                   @default("[]") @map("detected_social_links")
  detectedPlatforms   Json                   @default("[]") @map("detected_platforms")
  detectedLocation    String?                @map("detected_location")
  detectedActivity    String?                @map("detected_activity")
  extractedSummary    String?                @map("extracted_summary")
  confidenceScore     Int                    @default(0) @map("confidence_score")
  status              EnrichmentStatus       @default(pending)
  errorMessage        String?                @map("error_message")
  createdAt           DateTime               @default(now()) @map("created_at") @db.Timestamptz
  updatedAt           DateTime               @default(now()) @map("updated_at") @db.Timestamptz
  organization        Organization           @relation(fields: [organizationId], references: [id])
  prospect            Prospect               @relation(fields: [prospectId], references: [id])

  @@index([prospectId, createdAt])
  @@index([organizationId, status, createdAt])
  @@index([organizationId, sourceType, confidenceScore])
  @@index([organizationId, createdAt])
  @@index([organizationId, confidenceScore])
  @@map("prospect_enrichments")
}

model ProspectFieldSuggestion {
  id              String           @id @db.Uuid
  organizationId  String           @map("organization_id") @db.Uuid
  prospectId      String           @map("prospect_id") @db.Uuid
  fieldName       String           @map("field_name")
  currentValue    String?          @map("current_value")
  suggestedValue  String           @map("suggested_value")
  sourceUrl       String           @map("source_url")
  confidenceScore Int              @default(0) @map("confidence_score")
  status          SuggestionStatus @default(pending)
  createdAt       DateTime         @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime         @default(now()) @map("updated_at") @db.Timestamptz
  organization    Organization     @relation(fields: [organizationId], references: [id])
  prospect        Prospect         @relation(fields: [prospectId], references: [id])

  @@index([prospectId, status, createdAt])
  @@index([organizationId, status, createdAt])
  @@index([prospectId, organizationId, status, createdAt])
  @@map("prospect_field_suggestions")
}

enum EnrichmentSourceType {
  website
  instagram_public
  x_public
  linktree
  allmylinks
  mym_public
  onlyfans_public
  other
}

enum EnrichmentStatus {
  pending
  success
  partial
  failed
  blocked
  skipped
}

enum SuggestionStatus {
  pending
  accepted
  rejected
}

model CrmActivityLog {
  id             String       @id @db.Uuid
  organizationId String       @map("organization_id") @db.Uuid
  userId         String?      @map("user_id") @db.Uuid
  prospectId     String?      @map("prospect_id") @db.Uuid
  actionType     String       @map("action_type")
  previousValue  String?      @map("previous_value")
  newValue       String?      @map("new_value")
  metadata       Json         @default("{}")
  createdAt      DateTime     @default(now()) @map("created_at") @db.Timestamptz
  organization   Organization @relation(fields: [organizationId], references: [id])
  user           User?        @relation(fields: [userId], references: [id])
  prospect       Prospect?    @relation(fields: [prospectId], references: [id])

  @@index([organizationId, createdAt])
  @@index([prospectId, createdAt])
  @@index([organizationId, actionType, createdAt])
  @@index([organizationId, userId, createdAt])
  @@map("crm_activity_log")
}

model AuditTrail {
  id             String       @id @db.Uuid
  organizationId String?      @map("organization_id") @db.Uuid
  userId         String?      @map("user_id") @db.Uuid
  ip             String?
  userAgent      String?      @map("user_agent")
  traceId        String?      @map("trace_id")
  action         String
  resource       String
  resourceId     String?      @map("resource_id")
  before         Json?
  after          Json?
  createdAt      DateTime     @default(now()) @map("created_at") @db.Timestamptz
  organization   Organization? @relation(fields: [organizationId], references: [id])
  user           User?        @relation(fields: [userId], references: [id])

  @@index([organizationId, createdAt])
  @@index([userId, createdAt])
  @@index([action, createdAt])
  @@index([traceId])
  @@map("audit_trail")
}

model AppSetting {
  id             String        @id @db.Uuid
  organizationId String?       @map("organization_id") @db.Uuid
  key            String
  value          Json          @default("{}")
  createdAt      DateTime      @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime      @default(now()) @map("updated_at") @db.Timestamptz
  organization   Organization? @relation(fields: [organizationId], references: [id])

  @@unique([organizationId, key])
  @@index([organizationId, key])
  @@map("app_settings")
}

model AiChatSession {
  id             String          @id @db.Uuid
  organizationId String          @map("organization_id") @db.Uuid
  userId         String?         @map("user_id") @db.Uuid
  title          String          @default("Nouvelle conversation")
  createdAt      DateTime        @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime        @default(now()) @map("updated_at") @db.Timestamptz
  organization   Organization    @relation(fields: [organizationId], references: [id])
  user           User?           @relation(fields: [userId], references: [id])
  messages       AiChatMessage[]

  @@index([organizationId, updatedAt])
  @@map("ai_chat_sessions")
}

model AiChatMessage {
  id             String        @id @db.Uuid
  sessionId      String        @map("session_id") @db.Uuid
  organizationId String        @map("organization_id") @db.Uuid
  userId         String?       @map("user_id") @db.Uuid
  role           String
  content        String
  intent         String?
  citations      Json          @default("[]")
  resultCsv      String?       @map("result_csv")
  createdAt      DateTime      @default(now()) @map("created_at") @db.Timestamptz
  session        AiChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  organization   Organization  @relation(fields: [organizationId], references: [id])
  user           User?         @relation(fields: [userId], references: [id])

  @@index([sessionId, createdAt])
  @@map("ai_chat_messages")
}

model SiteQaItem {
  id             String       @id @db.Uuid
  organizationId String       @map("organization_id") @db.Uuid
  siteId         String       @map("site_id") @db.Uuid
  category       String       @default("general")
  question       String
  answer         String
  tags           String[]     @default([])
  priority       Int          @default(50)
  isActive       Boolean      @default(true) @map("is_active")
  createdAt      DateTime     @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime     @default(now()) @map("updated_at") @db.Timestamptz
  organization   Organization @relation(fields: [organizationId], references: [id])

  @@unique([siteId, question])
  @@index([siteId, isActive, priority])
  @@index([organizationId, createdAt])
  @@map("site_qa_items")
}

model ChatbotUnansweredQuestion {
  id              String       @id @db.Uuid
  organizationId  String       @map("organization_id") @db.Uuid
  siteId          String       @map("site_id") @db.Uuid
  conversationId  String?      @map("conversation_id") @db.Uuid
  question        String
  status          String       @default("pending")
  suggestedAnswer String?      @map("suggested_answer")
  category        String?
  tags            String[]     @default([])
  detectedIntent  String?      @map("detected_intent")
  occurrenceCount Int          @default(1) @map("occurrence_count")
  lastSeenAt      DateTime?    @map("last_seen_at") @db.Timestamptz
  confidenceScore Decimal?     @map("confidence_score")
  suggestedKnowledgeItem String? @map("suggested_knowledge_item") @db.Uuid
  actionStatus    String       @default("pending") @map("action_status")
  createdAt       DateTime     @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime     @default(now()) @map("updated_at") @db.Timestamptz
  organization    Organization @relation(fields: [organizationId], references: [id])

  @@index([siteId, status, createdAt])
  @@index([organizationId, createdAt])
  @@map("chatbot_unanswered_questions")
}

model ChatbotIntent {
  id             String       @id @db.Uuid
  organizationId String       @map("organization_id") @db.Uuid
  siteId         String       @map("site_id") @db.Uuid
  name           String
  slug           String
  description    String?
  category       String       @default("general")
  examples       String[]     @default([])
  synonyms       String[]     @default([])
  priority       Int          @default(50)
  isActive       Boolean      @default(true) @map("is_active")
  createdAt      DateTime     @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime     @default(now()) @map("updated_at") @db.Timestamptz
  organization   Organization @relation(fields: [organizationId], references: [id])
  knowledgeItems KnowledgeItem[]

  @@unique([siteId, slug])
  @@index([siteId, isActive, priority])
  @@map("chatbot_intents")
}

model KnowledgeItem {
  id                   String       @id @db.Uuid
  organizationId       String       @map("organization_id") @db.Uuid
  siteId               String       @map("site_id") @db.Uuid
  intentId             String?      @map("intent_id") @db.Uuid
  title                String
  mainQuestion         String       @map("main_question")
  alternativeQuestions String[]     @default([]) @map("alternative_questions")
  shortAnswer          String       @map("short_answer")
  detailedAnswer       String?      @map("detailed_answer")
  commercialAnswer     String?      @map("commercial_answer")
  reassuranceAnswer    String?      @map("reassurance_answer")
  links                String[]     @default([])
  ctaLabel             String?      @map("cta_label")
  ctaUrl               String?      @map("cta_url")
  conditions           String?
  tags                 String[]     @default([])
  priority             Int          @default(50)
  status               String       @default("draft")
  version              Int          @default(1)
  createdByUserId      String?      @map("created_by_user_id") @db.Uuid
  updatedByUserId      String?      @map("updated_by_user_id") @db.Uuid
  createdAt            DateTime     @default(now()) @map("created_at") @db.Timestamptz
  updatedAt            DateTime     @default(now()) @map("updated_at") @db.Timestamptz
  organization         Organization @relation(fields: [organizationId], references: [id])
  intent               ChatbotIntent? @relation(fields: [intentId], references: [id])

  @@index([siteId, status, priority])
  @@index([organizationId, updatedAt])
  @@map("knowledge_items")
}

model ConversationFlow {
  id              String       @id @db.Uuid
  organizationId  String       @map("organization_id") @db.Uuid
  siteId          String       @map("site_id") @db.Uuid
  name            String
  description     String?
  triggerIntentId String?      @map("trigger_intent_id") @db.Uuid
  isActive        Boolean      @default(true) @map("is_active")
  createdAt       DateTime     @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime     @default(now()) @map("updated_at") @db.Timestamptz
  organization    Organization @relation(fields: [organizationId], references: [id])
  steps           ConversationFlowStep[]

  @@index([siteId, isActive])
  @@map("conversation_flows")
}

model ConversationFlowStep {
  id         String           @id @db.Uuid
  flowId     String           @map("flow_id") @db.Uuid
  stepOrder  Int              @map("step_order")
  stepType   String           @map("step_type")
  content    String
  conditions String?
  nextStepId String?          @map("next_step_id") @db.Uuid
  actionType String?          @map("action_type")
  metadata   Json             @default("{}")
  createdAt  DateTime         @default(now()) @map("created_at") @db.Timestamptz
  updatedAt  DateTime         @default(now()) @map("updated_at") @db.Timestamptz
  flow       ConversationFlow @relation(fields: [flowId], references: [id], onDelete: Cascade)

  @@index([flowId, stepOrder])
  @@map("conversation_flow_steps")
}

model ChatbotPersonality {
  id                  String       @id @db.Uuid
  organizationId      String       @map("organization_id") @db.Uuid
  siteId              String       @unique @map("site_id") @db.Uuid
  tone                String       @default("professionnel")
  style               String?
  answerLength        String       @default("medium") @map("answer_length")
  formality           String       @default("vouvoiement")
  emojiLevel          String       @default("none") @map("emoji_level")
  commercialIntensity Int          @default(50) @map("commercial_intensity")
  reassuranceLevel    Int          @default(70) @map("reassurance_level")
  createdAt           DateTime     @default(now()) @map("created_at") @db.Timestamptz
  updatedAt           DateTime     @default(now()) @map("updated_at") @db.Timestamptz
  organization        Organization @relation(fields: [organizationId], references: [id])

  @@map("chatbot_personality")
}

model ChatbotGoal {
  id             String       @id @db.Uuid
  organizationId String       @map("organization_id") @db.Uuid
  siteId         String       @map("site_id") @db.Uuid
  goalType       String       @map("goal_type")
  description    String
  priority       Int          @default(50)
  successAction  String?      @map("success_action")
  isActive       Boolean      @default(true) @map("is_active")
  createdAt      DateTime     @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime     @default(now()) @map("updated_at") @db.Timestamptz
  organization   Organization @relation(fields: [organizationId], references: [id])

  @@index([siteId, isActive, priority])
  @@map("chatbot_goals")
}

model KnowledgeSuggestion {
  id                String       @id @db.Uuid
  organizationId    String       @map("organization_id") @db.Uuid
  siteId            String       @map("site_id") @db.Uuid
  sourceType        String       @map("source_type")
  sourceId          String?      @map("source_id") @db.Uuid
  suggestedIntent   String?      @map("suggested_intent")
  suggestedQuestion String       @map("suggested_question")
  suggestedAnswer   String       @map("suggested_answer")
  suggestedTags     String[]     @default([]) @map("suggested_tags")
  confidenceScore   Decimal?     @map("confidence_score")
  status            String       @default("pending")
  createdAt         DateTime     @default(now()) @map("created_at") @db.Timestamptz
  updatedAt         DateTime     @default(now()) @map("updated_at") @db.Timestamptz
  organization      Organization @relation(fields: [organizationId], references: [id])

  @@index([siteId, status, createdAt])
  @@map("knowledge_suggestions")
}

model ChatbotStudio {
  id                   String       @id @db.Uuid
  organizationId       String       @map("organization_id") @db.Uuid
  siteId               String       @unique @map("site_id") @db.Uuid
  name                 String
  domain               String?
  businessType         String       @default("autre") @map("business_type")
  primaryGoal          String       @default("information") @map("primary_goal")
  tone                 String       @default("professionnel")
  currentStage         String       @default("draft") @map("current_stage")
  draftVersion         Int          @default(1) @map("draft_version")
  preproductionVersion Int?         @map("preproduction_version")
  publishedVersion     Int?         @map("published_version")
  lastPublishedAt      DateTime?    @map("last_published_at") @db.Timestamptz
  createdAt            DateTime     @default(now()) @map("created_at") @db.Timestamptz
  updatedAt            DateTime     @default(now()) @map("updated_at") @db.Timestamptz
  organization         Organization @relation(fields: [organizationId], references: [id])

  @@index([organizationId, currentStage])
  @@map("chatbot_studios")
}

model ChatbotStudioVersion {
  id             String       @id @db.Uuid
  organizationId String       @map("organization_id") @db.Uuid
  siteId         String       @map("site_id") @db.Uuid
  versionNumber  Int          @map("version_number")
  status         String       @default("draft")
  snapshot       Json         @default("{}")
  publishedAt    DateTime?    @map("published_at") @db.Timestamptz
  createdAt      DateTime     @default(now()) @map("created_at") @db.Timestamptz
  organization   Organization @relation(fields: [organizationId], references: [id])

  @@unique([siteId, versionNumber])
  @@index([siteId, createdAt])
  @@map("chatbot_studio_versions")
}

model ChatbotTemplateLibrary {
  id           String   @id
  name         String
  businessType String   @map("business_type")
  description  String?
  payload      Json     @default("{}")
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz

  @@map("chatbot_template_library")
}

model ChatbotImportProposal {
  id                 String       @id @db.Uuid
  organizationId     String       @map("organization_id") @db.Uuid
  siteId             String       @map("site_id") @db.Uuid
  fileName           String       @map("file_name")
  fileType           String       @map("file_type")
  extractedQuestions String[]     @default([]) @map("extracted_questions")
  extractedLinks     String[]     @default([]) @map("extracted_links")
  proposedKnowledge  Json         @default("[]") @map("proposed_knowledge")
  status             String       @default("pending")
  createdAt          DateTime     @default(now()) @map("created_at") @db.Timestamptz
  updatedAt          DateTime     @default(now()) @map("updated_at") @db.Timestamptz
  organization       Organization @relation(fields: [organizationId], references: [id])

  @@index([siteId, status, createdAt])
  @@map("chatbot_import_proposals")
}

model ChatbotSimulation {
  id              String       @id @db.Uuid
  organizationId  String       @map("organization_id") @db.Uuid
  siteId          String       @map("site_id") @db.Uuid
  message         String
