model VisitorConversationContext {
  id                    String       @id @db.Uuid
  organizationId        String       @map("organization_id") @db.Uuid
  siteId                String       @map("site_id") @db.Uuid
  conversationId        String       @unique @map("conversation_id") @db.Uuid
  visitorId             String       @map("visitor_id") @db.Uuid
  detectedNeeds         String?      @map("detected_needs")
  detectedCity          String?      @map("detected_city")
  detectedService       String?      @map("detected_service")
  detectedBudget        String?      @map("detected_budget")
  detectedUrgency       String?      @map("detected_urgency")
  detectedContactIntent String?      @map("detected_contact_intent")
  previousIntents       String[]     @default([]) @map("previous_intents")
  leadReadinessScore    Int          @default(0) @map("lead_readiness_score")
  createdAt             DateTime     @default(now()) @map("created_at") @db.Timestamptz
  updatedAt             DateTime     @default(now()) @map("updated_at") @db.Timestamptz
  organization          Organization @relation(fields: [organizationId], references: [id])

  @@index([organizationId, siteId, leadReadinessScore])
  @@map("visitor_conversation_context")
}

model ReasoningTrace {
  id                      String       @id @db.Uuid
  organizationId          String       @map("organization_id") @db.Uuid
  siteId                  String       @map("site_id") @db.Uuid
  conversationId          String       @map("conversation_id") @db.Uuid
  messageId               String?      @map("message_id") @db.Uuid
  detectedIntent          String       @map("detected_intent")
  intentConfidence        Decimal      @default(0) @map("intent_confidence") @db.Decimal(4, 3)
  selectedKnowledgeItemId String?      @map("selected_knowledge_item_id")
  appliedGoal             String?      @map("applied_goal")
  appliedPersonality      String?      @map("applied_personality")
  nextBestAction          String       @map("next_best_action")
  confidenceScore         Decimal      @default(0) @map("confidence_score") @db.Decimal(4, 3)
  knowledgeMatchScore     Decimal?     @map("knowledge_match_score") @db.Decimal(4, 3)
  goalAlignmentScore      Decimal?     @map("goal_alignment_score") @db.Decimal(4, 3)
  leadActionScore         Decimal?     @map("lead_action_score") @db.Decimal(4, 3)
  responseQualityScore    Decimal?     @map("response_quality_score") @db.Decimal(4, 3)
  traceJson               Json         @default("{}") @map("trace_json")
  createdAt               DateTime     @default(now()) @map("created_at") @db.Timestamptz
  organization            Organization @relation(fields: [organizationId], references: [id])

  @@index([conversationId, createdAt])
  @@index([organizationId, detectedIntent])
  @@index([organizationId, nextBestAction])
  @@map("reasoning_traces")
}

model ChatbotRuntimeMetric {
  id             String   @id @db.Uuid
  organizationId String   @map("organization_id") @db.Uuid
  siteId         String   @map("site_id") @db.Uuid
  conversationId String?  @map("conversation_id") @db.Uuid
  messageId      String?  @map("message_id") @db.Uuid
  totalTimeMs    Int      @default(0) @map("total_time_ms")
  knowledgeTimeMs Int     @default(0) @map("knowledge_time_ms")
  reasoningTimeMs Int     @default(0) @map("reasoning_time_ms")
  dbTimeMs       Int      @default(0) @map("db_time_ms")
  payloadBytes   Int      @default(0) @map("payload_bytes")
  responseBytes  Int      @default(0) @map("response_bytes")
  cacheHits      Int      @default(0) @map("cache_hits")
  cacheMisses    Int      @default(0) @map("cache_misses")
  errorCode      String?  @map("error_code")
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz

  @@index([siteId, createdAt])
