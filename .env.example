# VISITOR-OS environment example
# Do not store real secrets in this file.

NODE_ENV=development
APP_NAME=VISITOR-OS
HOST=0.0.0.0
PORT=3000
LOG_LEVEL=info
APP_URL=http://localhost:3000
ADMIN_URL=http://localhost:5173
WIDGET_URL=http://localhost:4173/widget.js

DATABASE_URL=postgresql://user:password@localhost:5432/visitor_os
DATABASE_SSL=false
DATABASE_CONNECTION_TIMEOUT_MS=5000

SESSION_SECRET=replace-with-local-development-secret

RESEND_API_KEY=
SENTRY_DSN=
OPENAI_API_KEY=

ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
SHUTDOWN_TIMEOUT_MS=10000
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=120
