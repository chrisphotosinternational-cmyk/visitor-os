# VISITOR-OS environment example
# Do not store real secrets in this file.

NODE_ENV=development
APP_NAME=VISITOR-OS
APP_URL=http://localhost:3000
ADMIN_URL=http://localhost:5173
WIDGET_URL=http://localhost:4173/widget.js

DATABASE_URL=postgresql://user:password@localhost:5432/visitor_os

SESSION_SECRET=replace-with-local-development-secret

RESEND_API_KEY=
SENTRY_DSN=
OPENAI_API_KEY=

ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
