# VISITOR-OS environment example
# Do not store real secrets in this file.

NODE_ENV=development
APP_NAME=VISITOR-OS
APP_VERSION=v1.0.0-RC1
HOST=0.0.0.0
PORT=3000
LOG_LEVEL=info
APP_URL=http://localhost:3000
ADMIN_URL=http://localhost:5173
WIDGET_URL=http://localhost:4173/widget.js

DATABASE_URL=postgresql://user:password@localhost:5432/visitor_os
DATABASE_SSL=false
DATABASE_CONNECTION_TIMEOUT_MS=5000

SESSION_SECRET=replace-with-local-development-secret

RESEND_API_KEY=
NOTIFICATION_FROM_EMAIL=notifications@visitor-os.local
NOTIFICATION_RETRY_ATTEMPTS=2
NOTIFICATION_TIMEOUT_MS=5000
SENTRY_DSN=
BUSINESS_CONFIG_DIR=../configs
ADMIN_SESSION_SECRET=change-this-session-secret-with-at-least-32-characters
ADMIN_SESSION_TTL_MS=86400000
ADMIN_SESSION_RENEWAL_MS=3600000
FIRST_ADMIN_EMAIL=admin@example.com
FIRST_ADMIN_PASSWORD=change-this-password
FIRST_ADMIN_FIRST_NAME=VISITOR
FIRST_ADMIN_LAST_NAME=Admin
FIRST_ADMIN_ORGANIZATION_ID=00000000-0000-4000-8000-000000000001

ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
SHUTDOWN_TIMEOUT_MS=10000
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=120
OPENAI_API_KEY=
